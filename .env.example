APP_NAME=mkit-api
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://api.mkit.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mkit
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.mkit.com.br

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@mkit.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Instagram OAuth (Meta Developer Console)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=https://api.mkit.com.br/auth/instagram/callback
# Test token for manual syncs — leave blank in production
INSTAGRAM_TEST_TOKEN=

# Frontend
FRONTEND_URL=https://mkit.com.br

# Sanctum — domínios “stateful” (sessão + CSRF no /api). Liste só hosts do front que
# compartilham cookies com esta API no mesmo site. NÃO use localhost:3000 se o Nuxt está
# em localhost e a API em dev.mkit.com.br com token Bearer — senão ocorre 419 CSRF.
SANCTUM_STATEFUL_DOMAINS=mkit.com.br,www.mkit.com.br,dev.mkit.com.br

# CORS — origens do front (obrigatório listar explicitamente se CORS_SUPPORTS_CREDENTIALS=true)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://mkit.com.br,https://dev.mkit.com.br
CORS_SUPPORTS_CREDENTIALS=true
